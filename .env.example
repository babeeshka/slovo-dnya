# MongoDB connection
# Get your connection string from MongoDB Atlas: https://mongodb.com/atlas
# Replace <db_password> with your database user password
MONGODB_URI=mongodb+srv://your_user:<db_password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0
MONGODB_DB=slovo_dnya

# Notification method: print | ntfy | email | osascript | discord
NOTIFY_METHOD=print

# ntfy.sh (free push notifications)
# Subscribe to this topic in the ntfy app on your phone
NTFY_TOPIC=slovo-dnya-yourname

# Email (HTML notifications via SMTP)
# For Gmail: create an app password at myaccount.google.com -> Security -> App passwords
EMAIL_FROM=
EMAIL_TO=
EMAIL_PASSWORD=
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587

# Discord webhook
# Create a webhook in your server: Server Settings -> Integrations -> Webhooks
DISCORD_WEBHOOK_URL=
